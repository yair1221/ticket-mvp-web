# Supabase (required)
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable / anon key (safe to expose). Never put the service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# PostHog analytics (required in production)
# Create a project at https://eu.posthog.com (EU region for GDPR)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Resend (required for /support form emails)
# Server-only — never exposed to client
RESEND_API_KEY=re_xxxxxxxx
SUPPORT_EMAIL_TO=support@ticketil.com
SUPPORT_EMAIL_FROM=noreply@ticketil.com

# App public URL (used in metadata, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://ticketil.com
